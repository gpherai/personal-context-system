# Local dev (npm run dev, DB via `docker compose up -d db`):
DATABASE_URL="postgresql://pcs:pcs@localhost:54329/personal_context_system"
CONTEXT_MIRROR_DIR="data/context-mirror"

# Docker Compose DB credentials (defaults above already match these — only
# needed if you want non-default credentials, e.g. on a shared VPS):
# POSTGRES_USER="pcs"
# POSTGRES_PASSWORD="pcs"
# POSTGRES_DB="personal_context_system"

# Docker Compose `app` service port binding (VPS deployment only):
# APP_HOST="10.0.0.30"
# APP_PORT="53101"
